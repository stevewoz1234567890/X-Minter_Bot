# X API v2 (Bearer token from developer portal)
TWITTER_BEARER_TOKEN=

# Solana RPC + creator wallet (base58-encoded secret key; 64-byte preferred)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=

# Telegram bot (@BotFather) + your chat id (e.g. from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated; first run only sets cursor (no historical mint)
WATCH_USERNAMES=elonmusk
WATCH_KEYWORDS=doge,meme

BOT_POLL_INTERVAL_MS=25000
BOT_STATE_FILE=./bot-state.json
BOT_EXCLUDE_RETWEETS=true
BOT_EXCLUDE_REPLIES=false
